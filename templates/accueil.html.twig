{% extends 'base.html.twig' %}

{% block title %}
    Accueil
{% endblock %}

{% block body %}

	<div class="accueil">
		<div class="block-accueil">
			<h2>Découvrez nos créations gourmandes</h2>
			<h5>Des pâtisseries fines pour chaque moment spécial</h5>
			<a href="{{ path('produit', { 'id' : 13 }) }}" class="button">
				Voir maintenant
			</a>
		</div>
		<img src="{{ path('produit_image', {'id': 13}) }}" 
			alt="Image du produit" class="image-accueil">
	</div>

	<div class="block-text">
		<div class="sous-block-text">
			<p>“Le Meilleur Gâteau au Chocolat que J'ai Jamais Mangé !”</p>
			<h6>Hawa.L</h6>
		</div>
		<div class="sous-block-text">
			<p>“Une Explosion de Saveurs avec Chaque Cuillère !”</p>
			<h6>Zeinab.T</h6>
		</div>
		<div class="sous-block-text">
			<p>“Le Délice Parfait pour Commencer la Journée”</p>
			<h6>Astou.D</h6>
		</div>
	</div>

	<div class="page">
		{% for i in produit %}
			<div class="block">
				<div class="sous-block">
					<h3>{{ i.nom }}</h3>
					<p> {{ i.prix }}€</p>
					<p>{{ i.description }}</p>
					<a href="{{ path('produit', { 'id' : i.id })}}" class="button">
						En savoir plus 
					</a>
				</div>
				<img src="{{ path('produit_image', {'id': i.id}) }}" 
					alt="Image du produit" class="image">
			</div>
		{% endfor %}
	</div>

{% endblock %}